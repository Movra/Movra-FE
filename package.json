{
  "name": "movrara-fe",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:visual": "vite --host 127.0.0.1 --port 5175 --mode visual --strictPort",
    "mock:visual": "node scripts/visual-mock-api.cjs",
    "smoke:visual": "node scripts/visual-smoke.cjs",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@stomp/stompjs": "^7.3.0",
    "@tanstack/react-query": "^5.59.16",
    "react": "^18.3.1",
